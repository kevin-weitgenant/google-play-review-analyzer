{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Backend: Start Dev Server",
            "type": "shell",
            "command": "uv run uvicorn app.main:app --reload --port 8000",
            "options": {
                "cwd": "${workspaceFolder}/google-play-review-analyzer/backend"
            },
            "isBackground": true,
            "problemMatcher": [],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "dev-servers"
            }
        },
        {
            "label": "Frontend: Start Dev Server",
            "type": "shell",
            "command": "pnpm dev",
            "options": {
                "cwd": "${workspaceFolder}/google-play-review-analyzer/frontend"
            },
            "isBackground": true,
            "problemMatcher": [],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "dev-servers"
            }
        },
        {
            "label": "Dev: Start Both (Frontend + Backend)",
            "dependsOn": [
                "Backend: Start Dev Server",
                "Frontend: Start Dev Server"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "dev-servers"
            }
        }
    ]
}
